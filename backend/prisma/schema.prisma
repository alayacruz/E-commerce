// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS
enum Gender {
  male
  female
  others
}

// MODELS

model User {
  user_id      String        @id
  email_id     String        @unique
  password     String
  first_name   String
  last_name    String?
  phoneNumbers PhoneNumber[]
  seller       Seller?
  buyer        Buyer?
  addresses    Address[]
  orders       Order[]
}

model PhoneNumber {
  user_id  String
  phone_no String

  user User @relation(fields: [user_id], references: [user_id])

  @@id([user_id, phone_no])
}

model Seller {
  seller_id String @id
  gst_no    String

  user      User       @relation(fields: [seller_id], references: [user_id])
  shipments Shipment[]
}

model Buyer {
  buyer_id String   @id
  gender   Gender
  dob      DateTime

  user      User       @relation(fields: [buyer_id], references: [user_id])
  addresses Address[]
  orders    Order[]
  shipments Shipment[]
}

model Address {
  address_id Int    @id @default(autoincrement())
  user_id    String
  street     String
  city       String
  state      String
  country    String
  pin        String

  addresses Buyer[]
  user      User    @relation(fields: [user_id], references: [user_id])
}

model Order {
  order_id   String   @id
  order_date DateTime
  status     String
  amount     Decimal
  buyer_id   String

  buyer       Buyer       @relation(fields: [buyer_id], references: [buyer_id])
  items       OrderItem[]
  shipment    Shipment[]
  User        User?       @relation(fields: [userUser_id], references: [user_id])
  userUser_id String?
}

model OrderItem {
  order_item_id String @id
  order_id      String
  product_id    String
  quantity      Int

  order Order @relation(fields: [order_id], references: [order_id])
}

model Shipment {
  shipment_id     String    @id
  tracking_no     String    @unique
  carrier         String
  shipment_status String
  delivery_date   DateTime?

  seller_id String
  buyer_id  String
  order_id  String

  seller Seller @relation(fields: [seller_id], references: [seller_id])
  buyer  Buyer  @relation(fields: [buyer_id], references: [buyer_id])
  order  Order  @relation(fields: [order_id], references: [order_id])
}