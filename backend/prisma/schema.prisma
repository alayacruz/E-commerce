generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id      String        @id @default(uuid())
  email_id     String        @unique
  password     String
  first_name   String
  last_name    String?
  addresses    Address[]
  buyer        Buyer?
  orders       Order[]
  phoneNumbers PhoneNumber[]
  seller       Seller?
}

model PhoneNumber {
  user_id  String
  phone_no String
  user     User   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([user_id, phone_no])
}

model Seller {
  seller_id String     @id @default(uuid())
  gst_no    String
  products  Product[]
  user      User       @relation(fields: [seller_id], references: [user_id], onDelete: Cascade)
  shipments Shipment[]
}

model Buyer {
  buyer_id  String     @id @default(uuid())
  gender    Gender
  dob       DateTime
  addresses Address[]
  user      User       @relation(fields: [buyer_id], references: [user_id], onDelete: Cascade)
  carts     Cart?
  orders    Order[]
  payments  Payment[]
  reviews   Review[]
  shipments Shipment[]
}

model Address {
  address_id    Int     @id @default(autoincrement())
  user_id       String
  street        String
  city          String
  state         String
  country       String
  pin           String
  buyerBuyer_id String?
  Buyer         Buyer?  @relation(fields: [buyerBuyer_id], references: [buyer_id], onDelete: Cascade)
  user          User    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model Order {
  order_id    String      @id @default(uuid())
  order_date  DateTime
  status      String
  amount      Decimal
  buyer_id    String
  userUser_id String?
  buyer       Buyer       @relation(fields: [buyer_id], references: [buyer_id], onDelete: Cascade)
  User        User?       @relation(fields: [userUser_id], references: [user_id], onDelete: Cascade)
  items       OrderItem[]
  payments    Payment[]
  shipment    Shipment[]
}

model OrderItem {
  order_item_id String  @id @default(uuid())
  order_id      String
  product_id    String
  quantity      Int
  order         Order   @relation(fields: [order_id], references: [order_id], onDelete: Cascade)
  product       Product @relation(fields: [product_id], references: [productId], onDelete: Cascade)
}

model Shipment {
  shipment_id     String    @id
  tracking_no     String    @unique
  carrier         String
  shipment_status String
  delivery_date   DateTime?
  seller_id       String
  buyer_id        String
  order_id        String
  buyer           Buyer     @relation(fields: [buyer_id], references: [buyer_id], onDelete: Cascade)
  order           Order     @relation(fields: [order_id], references: [order_id], onDelete: Cascade)
  seller          Seller    @relation(fields: [seller_id], references: [seller_id], onDelete: Cascade)
}

model Product {
  productId         String      @id @default(uuid()) @db.VarChar(36)
  name              String      @db.VarChar(50)
  description       String?     @db.VarChar(200)
  price             Decimal     @db.Decimal(10, 2)
  availableQuantity Int
  status            String?
  seller_id         String
  imageUrls         String[]
  originalPrice     Decimal?    @db.Decimal(10, 2)
  features          String[]
  specifications    Json?
  categoryId        Int?
  isArchived        Boolean     @default(false)
  cartItems         CartItem[]
  orderItems        OrderItem[]
  category          Category?   @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade)
  seller            Seller      @relation(fields: [seller_id], references: [seller_id], onDelete: Cascade)
  reviews           Review[]
}

model Payment {
  paymentId               String   @id @default(uuid()) @db.VarChar(36)
  amount                  Decimal  @db.Decimal(10, 2)
  status                  String   @db.VarChar(30)
  date                    DateTime
  method                  String
  orderId                 String
  buyerId                 String
  external_transaction_id String
  external_capture_id     String?
  buyer                   Buyer    @relation(fields: [buyerId], references: [buyer_id], onDelete: Cascade)
  order                   Order    @relation(fields: [orderId], references: [order_id], onDelete: Cascade)
}

model Review {
  reviewId  String   @id @default(uuid()) @db.VarChar(36)
  text      String
  rating    Int
  date      DateTime
  productId String
  buyerId   String
  buyer     Buyer    @relation(fields: [buyerId], references: [buyer_id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [productId], onDelete: Cascade)
}

model Cart {
  cartId  String     @id @unique @default(uuid()) @db.VarChar(36)
  buyerId String     @unique
  buyer   Buyer      @relation(fields: [buyerId], references: [buyer_id], onDelete: Cascade)
  items   CartItem[]
}

model CartItem {
  cartItemId String  @id @default(uuid()) @db.VarChar(36)
  cartId     String
  productId  String  @default(uuid())
  quantity   Int
  cart       Cart    @relation(fields: [cartId], references: [cartId], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [productId], onDelete: Cascade)
}

model Category {
  categoryId       Int        @id @default(autoincrement())
  categoryName     String     @db.VarChar(100)
  parentCategoryId Int?
  parentCategory   Category?  @relation("ParentChildCategory", fields: [parentCategoryId], references: [categoryId], onDelete: Cascade)
  subcategories    Category[] @relation("ParentChildCategory")
  products         Product[]
}

enum Gender {
  male
  female
  others
}
